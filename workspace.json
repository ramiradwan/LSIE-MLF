{
  "ci_commands": [
    {
      "step": "ruff-lint-autofix",
      "cmd": ["ruff", "check", "--fix", "packages/", "services/", "tests/"]
    },
    {
      "step": "ruff-format-autofix",
      "cmd": ["ruff", "format", "packages/", "services/", "tests/"]
    },
    {
      "step": "mypy",
      "cmd": [
        "mypy", "packages/", "services/", "tests/",
        "--python-version", "3.11",
        "--ignore-missing-imports",
        "--explicit-package-bases"
      ]
    },
    {
      "step": "tests",
      "cmd": ["pytest", "tests/", "-x", "-q", "--tb=short"]
    }
  ]
}