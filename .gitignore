# LSIE-MLF .gitignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/

# Environment
.env
.env.*
!.env.example

# Data directories (transient/debug/processed)
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# Docker
*.log

# Ignore agent implementation artifacts and scaffolding
.claude/settings.local.json
.workspace*
docs/artifacts/
