# LSIE-MLF .gitignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/*
!build/
!build/sign_windows.ps1
!build/MACOS_DEFERRED.md
.venv/
venv/

# Environment
.env
.env.*
!.env.example

# Data directories (transient/debug/processed)
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# Docker
*.log

# Ignore agent implementation artifacts and scaffolding
.claude/settings.local.json
.workspace*
docs/artifacts/*
# docs/artifacts/ is scratch-only by default. Allowlist specific files that
# are frozen historical records worth tracking (point-in-time snapshots that
# don't change) or append-only logs maintained by the playbook.
!docs/artifacts/performance_baseline.md
!docs/artifacts/HARDENING_SUMMARY.md

# docs/content.json is regenerated from the single docs/tech-spec-v*.pdf via
# scripts/spec_ref_check.py --extract. Source of truth is the signed PDF.
docs/content.json
