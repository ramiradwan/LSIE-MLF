# LSIE-MLF Environment Configuration
# Copy to .env and fill in values before running docker compose up

# --- Persistent Store (§9.1) ---
POSTGRES_USER=lsie
POSTGRES_PASSWORD=changeme
POSTGRES_DB=lsie_mlf
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Message Broker (§9.1) ---
REDIS_URL=redis://redis:6379/0

# --- Physiological Webhooks (§4.B.2) ---
OURA_WEBHOOK_SECRET=
PHYSIO_STALENESS_THRESHOLD_S=600

# --- Azure OpenAI (§8.1) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-01

# --- EulerStream Signature API (§4.B) ---
EULERSTREAM_SIGN_URL=

# --- Ephemeral Vault (§5.1) ---
VAULT_SHRED_INTERVAL_HOURS=24

# --- Drift Correction (§4.C.1) ---
DRIFT_POLL_INTERVAL_SECONDS=30
MAX_TOLERATED_DRIFT_MS=150

# --- ADB Remote Server (§4.A) ---
# Used by stream_scrcpy, worker, and orchestrator containers to connect
# to the ADB server running on the Docker host (outside the container).
ADB_SERVER_SOCKET=tcp:host.docker.internal:5037

# --- Spec Trust Gate ---
TRUSTED_SPEC_SIGNERS=

# --- Stimulus Trigger Timer (§4.C) ---
# Seconds after orchestrator start to auto-inject a Thompson Sampling stimulus.
# Set to 0 to disable auto-trigger and wait for manual trigger via
# POST /api/v1/stimulus or Redis pub/sub on the stimulus:trigger channel.
AUTO_STIMULUS_DELAY_S=0
