# LSIE-MLF environment example
# Copy to .env only for local development. Do not commit filled secrets.
# Cloud API base URLs must not include /v4; clients append versioned route paths.

# --- Spec verification ---
# Optional: comma-separated trusted signer organization names for full spec signature validation.
TRUSTED_SPEC_SIGNERS=

# --- Desktop local runtime ---
# Optional overrides. Leave blank to use OS-appropriate defaults and PATH discovery.
LSIE_STATE_DIR=
LSIE_CAPTURE_DIR=
LSIE_ADB_PATH=
LSIE_SCRCPY_PATH=
LSIE_FFMPEG_PATH=
LSIE_API_PORT=8000
LSIE_API_URL=http://127.0.0.1:8000
# Development-only CPU speech fallback for machines below the production GPU floor.
LSIE_DEV_FORCE_CPU_SPEECH=0

# --- Desktop cloud sync client ---
# Base HTTPS origin for the retained cloud API; do not append /v4.
LSIE_CLOUD_BASE_URL=https://cloud.example.test
LSIE_CLOUD_CLIENT_ID=desktop-app
LSIE_CLOUD_SYNC_INTERVAL_S=5.0
LSIE_CLOUD_SYNC_BATCH_SIZE=50
LSIE_CLOUD_SYNC_TIMEOUT_S=15.0
LSIE_CLOUD_BUNDLE_ED25519_PUBLIC_KEY=

# --- Cloud API server/container ---
# Preferred cloud PostgreSQL names for services.cloud_api and the bootstrap command.
CLOUD_POSTGRES_HOST=
CLOUD_POSTGRES_PORT=5432
CLOUD_POSTGRES_USER=
CLOUD_POSTGRES_PASSWORD=
CLOUD_POSTGRES_DB=
LSIE_CLOUD_TOKEN_SIGNING_SECRET=
LSIE_CLOUD_ALLOWED_CLIENT_IDS=desktop-app
LSIE_CLOUD_BUNDLE_ED25519_PRIVATE_KEY=
LSIE_CLOUD_POLICY_VERSION=v4.0

# --- Optional semantic/LLM fallback ---
SEMANTIC_DEVICE_MODE=cuda:0
SEMANTIC_GRAY_BAND_FALLBACK_ENABLED=0
SEMANTIC_SHADOW_MODE_ENABLED=0
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-01

# --- Optional Oura physiology integration ---
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_WEBHOOK_SECRET=
OURA_TOKEN_FILE=
OURA_STATE_DIR=
